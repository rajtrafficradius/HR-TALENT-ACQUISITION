# ═══════════════════════════════════════════════════════════════════════════
#  Smart HR Talent Acquisition — environment variables
#  Copy to .env for local dev (gitignored). On Railway, set these as Variables.
# ═══════════════════════════════════════════════════════════════════════════

# ── Apollo.io ────────────────────────────────────────────────────────────────
# FREE People Search powers ALL discovery (no credits). Reveal (email/phone) via
# the per-candidate Enrich button COSTS credits and is the only paid path.
APOLLO_API_KEY=

# ── OpenAI (optional) ────────────────────────────────────────────────────────
# gpt-4o-mini refines role/technical scores (±15 cap) + a one-line blurb, and
# concisely summarizes CoreSignal LinkedIn records (JSON mode).
# Leave blank to run on pure heuristics — nothing breaks.
OPENAI_API_KEY=

# ── CoreSignal (optional) — manual LinkedIn enrichment ───────────────────────
# Powers the "LinkedIn Enrich" section (top right). PAID: each enrich consumes
# CoreSignal Search/Collect credits and is ONLY ever triggered manually per
# candidate. Auth uses the custom `apikey` header. Get the key at
# dashboard.coresignal.com → API keys. Leave blank to disable the feature.
CORESIGNAL_API_KEY=
# Employee dataset path segment. employee_multi_source = richest (300+ fields,
# 2 credits/call). Switch to employee_base / employee_clean if your plan lacks
# multi-source (1 credit/call, fewer fields).
CORESIGNAL_DATASET=employee_multi_source
# When CoreSignal can't match a candidate by name+company AND no LinkedIn URL is on
# file, fall back to ONE Apollo people/match (no email/phone reveal) to fetch the
# person's LinkedIn URL, then retry the precise CoreSignal lookup. 1=on, 0=off.
CORESIGNAL_APOLLO_LOOKUP=1

# ── MySQL (brand-new dedicated Railway service) ──────────────────────────────
# Priority: discrete MYSQL* vars > MYSQL_URL > MYSQL_PUBLIC_URL.
# On Railway, set the discrete vars (internal host, no egress fee).
# Locally, set MYSQL_PUBLIC_URL (the *.proxy.rlwy.net public proxy).
MYSQLHOST=
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=
MYSQLDATABASE=railway
MYSQL_URL=
MYSQL_PUBLIC_URL=

# Fail-closed: 0 = refuse to start discovery if DB is down. 1 = allow (debug only).
ALLOW_RUN_WITHOUT_DB=0

# ── Auth (single shared password) ────────────────────────────────────────────
# One password gates the whole app. SECRET_KEY signs the session cookie and MUST
# be set in production (generate: python -c "import secrets;print(secrets.token_hex(32))").
APP_PASSWORD=change-me
SECRET_KEY=
SESSION_COOKIE_SECURE=1          # 1 on Railway (HTTPS); 0 for local http

# ── Discovery defaults / tuning caps ─────────────────────────────────────────
HR_TARGET_DEPARTMENTS=sales,marketing,seo,digital_marketing
HR_PERSON_LOCATIONS=India,Australia      # default candidate region (UI can override per run)
HR_ORG_LOCATIONS=India,Australia
HR_SEED_DOMAINS=                          # optional extra company domains, comma-separated
HR_MAX_PAGES_PER_DEPT=10                  # Apollo 100/page -> up to 1000 people/dept/run
HR_MAX_CANDIDATES_PER_RUN=3000
HR_MAX_PER_CELL=40                        # cap per (category x region x size-band) cell,
                                          # so a run samples all company sizes evenly
HR_INCLUDE_GIANTS=0                       # 1 = also discover 10,001+ employee firms (giants)
HUNT_DOMAIN_BACKFILL_PER_TICK=40          # company websites resolved (free, Clearbit) per scheduler tick
HR_WEB_ENRICH_ENABLED=1                    # free homepage 'About' enricher (company description/tagline)
HUNT_WEB_ENRICH_PER_TICK=20               # company homepages fetched per scheduler tick
# Full company rosters: every company's complete employee list is pulled (free,
# domain-scoped Apollo search) so no company has only a few people.
HUNT_ROSTER_PER_TICK=4                     # companies fully rostered per scheduler tick
HR_MAX_ROSTER_PER_COMPANY=400              # cap people stored per company
HR_ROSTER_VERIFY_DEFAULT=0                 # default state of the Roster-verifier toggle
HR_INTENT_OPEN_THRESHOLD=60               # job_change_intent_score >= this => open_to_shift
HR_DAILY_REFRESH_ENABLED=1                # master switch: start the background scheduler thread
HR_COMPANY_CRAWL_ENABLED=0                # best-effort G2/Clutch domain crawl (off by default)
HR_COMPANY_CRAWL_MAX_REQUESTS=60

# ── Auto-hunt engine (the Discovery master toggle) ───────────────────────────
# When ON (toggled in the UI; persisted in DB), the scheduler continuously rotates
# the 28-category taxonomy, running FREE discovery slices (zero contact credits).
HR_AUTO_HUNT_DEFAULT=0                     # default state on a brand-new database
HUNT_INTERVAL_SECONDS=600                  # min gap between auto-hunt cycles
HUNT_CATEGORIES_PER_CYCLE=3               # categories swept per cycle (× seniority × region)
HUNT_MAX_PER_CYCLE=600                    # candidate cap per cycle
HUNT_PAGES_PER_CELL=1                     # Apollo pages per query cell per cycle
# HR_TARGET_GROUPS=SEO,Paid & Performance  # optional: restrict discovery to specific groups

# ── Enrichment safeguards (reveal costs Apollo credits) ──────────────────────
ENRICH_MAX_REVEALS_PER_RUN=25
ENRICH_MAX_REVEALS_PER_DAY_EMAIL=150
ENRICH_MAX_REVEALS_PER_DAY_PHONE=60

# ── Reserved for FUTURE LinkedIn integration (blank/off today) ───────────────
# When you obtain a LinkedIn API/crawler: fill the key, set LINKEDIN_ENABLED=1,
# and implement LinkedInIntentProvider.fetch() in core.py. No schema migration.
LINKEDIN_API_KEY=
LINKEDIN_ENABLED=0
LINKEDIN_MAX_LOOKUPS_PER_RUN=50

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
