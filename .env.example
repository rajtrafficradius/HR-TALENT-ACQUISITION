# ═══════════════════════════════════════════════════════════════════════════
#  Smart HR Talent Acquisition — environment variables
#  Copy to .env for local dev (gitignored). On Railway, set these as Variables.
# ═══════════════════════════════════════════════════════════════════════════

# ── Apollo.io ────────────────────────────────────────────────────────────────
# FREE People Search powers ALL discovery (no credits). Reveal (email/phone) via
# the per-candidate Enrich button COSTS credits and is the only paid path.
APOLLO_API_KEY=

# ── OpenAI (optional) ────────────────────────────────────────────────────────
# gpt-4o-mini refines role/technical scores (±15 cap) + a one-line blurb.
# Leave blank to run on pure heuristics — nothing breaks.
OPENAI_API_KEY=

# ── MySQL (brand-new dedicated Railway service) ──────────────────────────────
# Priority: discrete MYSQL* vars > MYSQL_URL > MYSQL_PUBLIC_URL.
# On Railway, set the discrete vars (internal host, no egress fee).
# Locally, set MYSQL_PUBLIC_URL (the *.proxy.rlwy.net public proxy).
MYSQLHOST=
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=
MYSQLDATABASE=railway
MYSQL_URL=
MYSQL_PUBLIC_URL=

# Fail-closed: 0 = refuse to start discovery if DB is down. 1 = allow (debug only).
ALLOW_RUN_WITHOUT_DB=0

# ── Auth (single shared password) ────────────────────────────────────────────
# One password gates the whole app. SECRET_KEY signs the session cookie and MUST
# be set in production (generate: python -c "import secrets;print(secrets.token_hex(32))").
APP_PASSWORD=change-me
SECRET_KEY=
SESSION_COOKIE_SECURE=1          # 1 on Railway (HTTPS); 0 for local http

# ── Discovery defaults / tuning caps ─────────────────────────────────────────
HR_TARGET_DEPARTMENTS=sales,marketing,seo,digital_marketing
HR_PERSON_LOCATIONS=India,Australia      # default candidate region (UI can override per run)
HR_ORG_LOCATIONS=India,Australia
HR_SEED_DOMAINS=                          # optional extra company domains, comma-separated
HR_MAX_PAGES_PER_DEPT=10                  # Apollo 100/page -> up to 1000 people/dept/run
HR_MAX_CANDIDATES_PER_RUN=3000
HR_INTENT_OPEN_THRESHOLD=60               # job_change_intent_score >= this => open_to_shift
HR_DAILY_REFRESH_ENABLED=1                # background daily discovery sweep
HR_COMPANY_CRAWL_ENABLED=0                # best-effort G2/Clutch domain crawl (off by default)
HR_COMPANY_CRAWL_MAX_REQUESTS=60

# ── Enrichment safeguards (reveal costs Apollo credits) ──────────────────────
ENRICH_MAX_REVEALS_PER_RUN=25
ENRICH_MAX_REVEALS_PER_DAY_EMAIL=150
ENRICH_MAX_REVEALS_PER_DAY_PHONE=60

# ── Reserved for FUTURE LinkedIn integration (blank/off today) ───────────────
# When you obtain a LinkedIn API/crawler: fill the key, set LINKEDIN_ENABLED=1,
# and implement LinkedInIntentProvider.fetch() in core.py. No schema migration.
LINKEDIN_API_KEY=
LINKEDIN_ENABLED=0
LINKEDIN_MAX_LOOKUPS_PER_RUN=50

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
